# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=qms_db

# JWT Security
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=1d

# LLM Providers (Pick at least one)
LLM_PROVIDER=google_gemini # openai, google_gemini, anthropic, ollama
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_anthropic_key
OLLAMA_BASE_URL=http://localhost:11434

# Email Service
EMAIL_SERVICE=smtp # smtp, sendgrid, resend
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_user
SMTP_PASS=your_pass
FROM_EMAIL=no-reply@qms-system.com

# File Storage
STORAGE_TYPE=local # local, gdrive, onedrive
LOCAL_STORAGE_PATH=./uploads
# GOOGLE_DRIVE_CLIENT_ID=your_id
# ONEDRIVE_CLIENT_ID=your_id
