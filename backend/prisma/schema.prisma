generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(uuid())
  slug          String         @unique
  name          String
  settings      String?        @db.LongText
  llmProvider   String?
  llmApiKey     String?        @db.Text
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  attachments   Attachment[]
  auditLogs     AuditLog[]
  customers     Customer[]
  emailLogs     EmailLog[]
  notifications Notification[]
  products      Product[]
  productPrices ProductPrice[]
  categories    Category[]
  manufacturers Manufacturer[]
  projects      Project[]
  quotes        QuoteRequest[]
  suppliers     Supplier[]
  teams         Team[]
  users         User[]

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  permissions String @db.LongText
  users       User[]

  @@map("roles")
}

model Team {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  leaderId String?
  leader   User?   @relation("TeamLeader", fields: [leaderId], references: [id])
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  users    User[]  @relation("TeamMembers")

  @@index([leaderId], map: "teams_leaderId_fkey")
  @@index([tenantId], map: "teams_tenantId_fkey")
  @@map("teams")
}

model User {
  id             String          @id @default(uuid())
  tenantId       String
  roleId         Int
  teamId         String?
  email          String
  password       String
  name           String
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  auditLogs      AuditLog[]
  notifications  Notification[]
  quotes         QuoteRequest[]  @relation("SalesQuotes")
  supplierQuotes SupplierQuote[] @relation("PurchasingQuotes")
  ledTeams       Team[]          @relation("TeamLeader")
  projects       ProjectMember[]
  customerQuotes CustomerQuote[]
  productPrices  ProductPrice[]
  role           Role            @relation(fields: [roleId], references: [id])
  team           Team?           @relation("TeamMembers", fields: [teamId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([roleId], map: "users_roleId_fkey")
  @@index([teamId], map: "users_teamId_fkey")
  @@map("users")
}

model Customer {
  id        String         @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  taxCode   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  projects  Project[]
  quotes    QuoteRequest[]

  @@index([tenantId], map: "customers_tenantId_fkey")
  @@map("customers")
}

model Supplier {
  id            String          @id @default(uuid())
  tenantId      String
  name          String
  email         String?
  phone         String?
  address       String?
  taxCode       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  quotes        SupplierQuote[]
  products      Product[]
  productPrices ProductPrice[]
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "suppliers_tenantId_fkey")
  @@map("suppliers")
}

model Product {
  id                 String              @id @default(uuid())
  tenantId           String
  sku                String
  partNumber         String?
  name               String
  unit               String?
  basePrice          Decimal             @db.Decimal(15, 2)
  isTemporary        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  description        String?             @db.Text
  categoryId         String?
  manufacturerId     String?
  supplierId         String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  manufacturer       Manufacturer?       @relation(fields: [manufacturerId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  quoteItems         QuoteRequestItem[]
  supplierQuoteItems SupplierQuoteItem[]
  prices             ProductPrice[]
  customerQuoteItems CustomerQuoteItem[]

  @@index([tenantId], map: "products_tenantId_fkey")
  @@index([categoryId])
  @@index([manufacturerId])
  @@map("products")
}

model ProductPrice {
  id              String    @id @default(uuid())
  tenantId        String
  productId       String
  supplierId      String
  originalPrice   Decimal   @db.Decimal(15, 2)
  discountPercent Decimal?  @db.Decimal(5, 2)
  unitPrice       Decimal   @db.Decimal(15, 2)
  taxRate         Decimal?  @db.Decimal(5, 2)
  currency        String    @default("VND")
  exchangeRate    Decimal?  @db.Decimal(15, 2)
  priceUsd        Decimal?  @db.Decimal(15, 2)
  leadTime        String?
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  source          String    @default("manual")
  sourceRefId     String?
  notes           String?   @db.Text
  createdById     String?
  createdAt       DateTime  @default(now())
  product         Product   @relation(fields: [productId], references: [id])
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  createdBy       User?     @relation(fields: [createdById], references: [id])

  @@index([productId, supplierId, validUntil])
  @@index([tenantId])
  @@map("product_prices")
}

model Category {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("categories")
}

model Manufacturer {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?   @db.Text
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("manufacturers")
}

model QuoteRequest {
  id             String             @id @default(uuid())
  tenantId       String
  salesId        String
  customerId     String
  projectId      String?
  status         String
  currentVersion Int                @default(1)
  expiryDate     DateTime?
  approvalDeadline DateTime?
  purchasingDeadline DateTime?
  totalAmount    Decimal            @db.Decimal(15, 2)
  subTotal       Decimal            @default(0) @db.Decimal(15, 2)   // Added for sub total before tax
  taxAmount      Decimal            @default(0) @db.Decimal(15, 2)   // Added for tax amount
  currency       String             @default("VND")
  slaDeadline    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  attachments    Attachment[]
  items          QuoteRequestItem[]
  customer       Customer           @relation(fields: [customerId], references: [id])
  project        Project?           @relation(fields: [projectId], references: [id])
  sales          User               @relation("SalesQuotes", fields: [salesId], references: [id])
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  customerQuotes CustomerQuote[]
  supplierQuotes SupplierQuote[]

  @@index([tenantId, status])
  @@index([customerId], map: "quote_requests_customerId_fkey")
  @@index([salesId], map: "quote_requests_salesId_fkey")
  @@map("quote_requests")
}

model QuoteRequestItem {
  id             String       @id @default(uuid())
  quoteRequestId String
  productId      String
  quantity       Decimal      @db.Decimal(15, 2)
  targetPrice    Decimal      @db.Decimal(15, 2)
  finalPrice     Decimal?     @db.Decimal(15, 2)
  priceExpiry    DateTime?
  product        Product      @relation(fields: [productId], references: [id])
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id])

  @@index([productId], map: "quote_request_items_productId_fkey")
  @@index([quoteRequestId], map: "quote_request_items_quoteRequestId_fkey")
  @@map("quote_request_items")
}

// QuoteVersion model removed

model SupplierQuote {
  id             String              @id @default(uuid())
  quoteRequestId String
  supplierId     String
  purchasingId   String
  totalAmount    Decimal             @db.Decimal(15, 2)
  currency       String              @default("VND")
  status         String
  createdAt      DateTime            @default(now())
  notes          String?             @db.Text
  items          SupplierQuoteItem[]
  attachments    Attachment[]
  purchasing     User                @relation("PurchasingQuotes", fields: [purchasingId], references: [id])
  quoteRequest   QuoteRequest        @relation(fields: [quoteRequestId], references: [id])
  supplier       Supplier            @relation(fields: [supplierId], references: [id])

  @@index([purchasingId], map: "supplier_quotes_purchasingId_fkey")
  @@index([quoteRequestId], map: "supplier_quotes_quoteRequestId_fkey")
  @@index([supplierId], map: "supplier_quotes_supplierId_fkey")
  @@map("supplier_quotes")
}

model SupplierQuoteItem {
  id              String        @id @default(uuid())
  supplierQuoteId String
  productId       String
  quantity        Decimal       @db.Decimal(15, 2)
  originalPrice   Decimal?      @db.Decimal(15, 2)   // Added original price
  discountPercent Decimal?      @db.Decimal(5, 2)    // Added discount percent
  taxRate         Decimal?      @db.Decimal(5, 2)    // Added tax rate
  unitPrice       Decimal       @db.Decimal(15, 2)
  product         Product       @relation(fields: [productId], references: [id])
  supplierQuote   SupplierQuote @relation(fields: [supplierQuoteId], references: [id])

  @@index([productId], map: "supplier_quote_items_productId_fkey")
  @@index([supplierQuoteId], map: "supplier_quote_items_supplierQuoteId_fkey")
  @@map("supplier_quote_items")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  tenantId  String
  userId    String
  type      String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  metadata  String?  @db.LongText
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId], map: "notifications_tenantId_fkey")
  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   String
  actorId    String
  entityType String
  entityId   String
  action     String
  oldData    String?  @db.LongText
  newData    String?  @db.LongText
  timestamp  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([actorId], map: "audit_logs_actorId_fkey")
  @@map("audit_logs")
}

model EmailLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String
  recipient    String
  subject      String
  status       String
  errorMessage String?  @db.Text
  sentAt       DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "email_logs_tenantId_fkey")
  @@map("email_logs")
}

model Attachment {
  id         String        @id @default(uuid())
  tenantId   String
  entityType String
  entityId   String
  fileName   String
  filePath   String        @db.Text
  fileSize   Int
  mimeType   String
  createdAt  DateTime      @default(now())
  quoteId    String?
  supplierQuoteId String?
  quote      QuoteRequest? @relation(fields: [quoteId], references: [id])
  supplierQuote SupplierQuote? @relation(fields: [supplierQuoteId], references: [id])
  tenant     Tenant        @relation(fields: [tenantId], references: [id])

  @@index([quoteId], map: "attachments_quoteId_fkey")
  @@index([tenantId], map: "attachments_tenantId_fkey")
  @@map("attachments")
}

model Project {
  id           String          @id @default(uuid())
  tenantId     String
  name         String
  description  String?         @db.Text
  status       String          @default("OPEN")
  customerId   String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  customer     Customer        @relation(fields: [customerId], references: [id])
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  members      ProjectMember[]
  quotes       QuoteRequest[]

  @@index([tenantId])
  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  role      String
  permissions String? @db.LongText

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId, role])
  @@map("project_members")
}

model CustomerQuote {
  id              String              @id @default(uuid())
  quoteRequestId  String
  versionLabel    String
  notes           String?             @db.Text
  totalAmount     Decimal             @db.Decimal(15, 2)
  subTotal        Decimal             @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal             @default(0) @db.Decimal(15, 2)
  currency        String              @default("VND")
  status          String              @default("DRAFT")
  isAccepted      Boolean             @default(false)
  acceptedAt      DateTime?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items           CustomerQuoteItem[]
  quoteRequest    QuoteRequest        @relation(fields: [quoteRequestId], references: [id])
  createdBy       User                @relation(fields: [createdById], references: [id])

  @@index([quoteRequestId])
  @@map("customer_quotes")
}

model CustomerQuoteItem {
  id               String        @id @default(uuid())
  customerQuoteId  String
  productId        String
  quantity         Decimal       @db.Decimal(15, 2)
  supplierPrice    Decimal       @db.Decimal(15, 2)
  expensePercent   Decimal?      @db.Decimal(5, 2)
  profitPercent    Decimal?      @db.Decimal(5, 2)
  taxPercent       Decimal?      @db.Decimal(5, 2)
  unitPrice        Decimal       @db.Decimal(15, 2)
  notes            String?       @db.Text

  customerQuote    CustomerQuote @relation(fields: [customerQuoteId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@index([customerQuoteId])
  @@map("customer_quote_items")
}
