generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(uuid())
  slug          String         @unique
  name          String
  settings      String?        @db.LongText
  llmProvider   String?
  llmApiKey     String?        @db.Text
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  attachments   Attachment[]
  auditLogs     AuditLog[]
  customers     Customer[]
  emailLogs     EmailLog[]
  notifications Notification[]
  products      Product[]
  categories    Category[]
  manufacturers Manufacturer[]
  quotes        QuoteRequest[]
  suppliers     Supplier[]
  teams         Team[]
  users         User[]

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  permissions String @db.LongText
  users       User[]

  @@map("roles")
}

model Team {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  leaderId String?
  leader   User?   @relation("TeamLeader", fields: [leaderId], references: [id])
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  users    User[]  @relation("TeamMembers")

  @@index([leaderId], map: "teams_leaderId_fkey")
  @@index([tenantId], map: "teams_tenantId_fkey")
  @@map("teams")
}

model User {
  id             String          @id @default(uuid())
  tenantId       String
  roleId         Int
  teamId         String?
  email          String
  password       String
  name           String
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  auditLogs      AuditLog[]
  notifications  Notification[]
  quotes         QuoteRequest[]  @relation("SalesQuotes")
  supplierQuotes SupplierQuote[] @relation("PurchasingQuotes")
  ledTeams       Team[]          @relation("TeamLeader")
  role           Role            @relation(fields: [roleId], references: [id])
  team           Team?           @relation("TeamMembers", fields: [teamId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([roleId], map: "users_roleId_fkey")
  @@index([teamId], map: "users_teamId_fkey")
  @@map("users")
}

model Customer {
  id        String         @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  taxCode   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  quotes    QuoteRequest[]

  @@index([tenantId], map: "customers_tenantId_fkey")
  @@map("customers")
}

model Supplier {
  id        String          @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  taxCode   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  quotes    SupplierQuote[]
  products  Product[]
  tenant    Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "suppliers_tenantId_fkey")
  @@map("suppliers")
}

model Product {
  id                 String              @id @default(uuid())
  tenantId           String
  sku                String
  name               String
  unit               String?
  basePrice          Decimal             @db.Decimal(15, 2)
  isTemporary        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  description        String?             @db.Text
  categoryId         String?
  manufacturerId     String?
  supplierId         String?
  priceExpiry        DateTime?
  leadTime           String?
  taxRate            Decimal?            @db.Decimal(5, 2)
  publicPrice        Decimal?            @db.Decimal(15, 2)
  exchangeRate       Decimal?            @db.Decimal(15, 2)
  priceUsd           Decimal?            @db.Decimal(15, 2)
  category           Category?           @relation(fields: [categoryId], references: [id])
  manufacturer       Manufacturer?       @relation(fields: [manufacturerId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  quoteItems         QuoteRequestItem[]
  supplierQuoteItems SupplierQuoteItem[]

  @@index([tenantId], map: "products_tenantId_fkey")
  @@index([categoryId])
  @@index([manufacturerId])
  @@map("products")
}

model Category {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("categories")
}

model Manufacturer {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?   @db.Text
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("manufacturers")
}

model QuoteRequest {
  id             String             @id @default(uuid())
  tenantId       String
  salesId        String
  customerId     String
  status         String
  currentVersion Int                @default(1)
  expiryDate     DateTime?
  approvalDeadline DateTime?
  purchasingDeadline DateTime?
  totalAmount    Decimal            @db.Decimal(15, 2)
  currency       String             @default("VND")
  slaDeadline    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  attachments    Attachment[]
  items          QuoteRequestItem[]
  customer       Customer           @relation(fields: [customerId], references: [id])
  sales          User               @relation("SalesQuotes", fields: [salesId], references: [id])
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  versions       QuoteVersion[]
  supplierQuotes SupplierQuote[]

  @@index([tenantId, status])
  @@index([customerId], map: "quote_requests_customerId_fkey")
  @@index([salesId], map: "quote_requests_salesId_fkey")
  @@map("quote_requests")
}

model QuoteRequestItem {
  id             String       @id @default(uuid())
  quoteRequestId String
  productId      String
  quantity       Decimal      @db.Decimal(15, 2)
  targetPrice    Decimal      @db.Decimal(15, 2)
  finalPrice     Decimal?     @db.Decimal(15, 2)
  priceExpiry    DateTime?
  product        Product      @relation(fields: [productId], references: [id])
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id])

  @@index([productId], map: "quote_request_items_productId_fkey")
  @@index([quoteRequestId], map: "quote_request_items_quoteRequestId_fkey")
  @@map("quote_request_items")
}

model QuoteVersion {
  id             String       @id @default(uuid())
  quoteRequestId String
  versionNumber  Int
  snapshotData   String       @db.LongText
  createdBy      String
  createdAt      DateTime     @default(now())
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id])

  @@index([quoteRequestId], map: "quote_versions_quoteRequestId_fkey")
  @@map("quote_versions")
}

model SupplierQuote {
  id             String              @id @default(uuid())
  quoteRequestId String
  supplierId     String
  purchasingId   String
  totalAmount    Decimal             @db.Decimal(15, 2)
  currency       String              @default("VND")
  status         String
  createdAt      DateTime            @default(now())
  items          SupplierQuoteItem[]
  purchasing     User                @relation("PurchasingQuotes", fields: [purchasingId], references: [id])
  quoteRequest   QuoteRequest        @relation(fields: [quoteRequestId], references: [id])
  supplier       Supplier            @relation(fields: [supplierId], references: [id])

  @@index([purchasingId], map: "supplier_quotes_purchasingId_fkey")
  @@index([quoteRequestId], map: "supplier_quotes_quoteRequestId_fkey")
  @@index([supplierId], map: "supplier_quotes_supplierId_fkey")
  @@map("supplier_quotes")
}

model SupplierQuoteItem {
  id              String        @id @default(uuid())
  supplierQuoteId String
  productId       String
  quantity        Decimal       @db.Decimal(15, 2)
  unitPrice       Decimal       @db.Decimal(15, 2)
  product         Product       @relation(fields: [productId], references: [id])
  supplierQuote   SupplierQuote @relation(fields: [supplierQuoteId], references: [id])

  @@index([productId], map: "supplier_quote_items_productId_fkey")
  @@index([supplierQuoteId], map: "supplier_quote_items_supplierQuoteId_fkey")
  @@map("supplier_quote_items")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  tenantId  String
  userId    String
  type      String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  metadata  String?  @db.LongText
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId], map: "notifications_tenantId_fkey")
  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   String
  actorId    String
  entityType String
  entityId   String
  action     String
  oldData    String?  @db.LongText
  newData    String?  @db.LongText
  timestamp  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([actorId], map: "audit_logs_actorId_fkey")
  @@map("audit_logs")
}

model EmailLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String
  recipient    String
  subject      String
  status       String
  errorMessage String?  @db.Text
  sentAt       DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "email_logs_tenantId_fkey")
  @@map("email_logs")
}

model Attachment {
  id         String        @id @default(uuid())
  tenantId   String
  entityType String
  entityId   String
  fileName   String
  filePath   String        @db.Text
  fileSize   Int
  mimeType   String
  createdAt  DateTime      @default(now())
  quoteId    String?
  quote      QuoteRequest? @relation(fields: [quoteId], references: [id])
  tenant     Tenant        @relation(fields: [tenantId], references: [id])

  @@index([quoteId], map: "attachments_quoteId_fkey")
  @@index([tenantId], map: "attachments_tenantId_fkey")
  @@map("attachments")
}
